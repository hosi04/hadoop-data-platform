# Force LF line endings for all shell scripts and text files
# Prevents CRLF issues when running scripts in WSL/Linux

* text=auto

*.sh        text eol=lf
*.py        text eol=lf
Makefile    text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.md        text eol=lf
*.env*      text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf

# Binary files — no line ending conversion
*.parquet   binary
*.avro      binary
*.orc       binary
