# Copy this file to .env and adjust values for your environment
# cp .env.example .env

# When running Spark inside Docker (spark container), use container hostnames
HDFS_HOST=namenode
HDFS_PORT=8020
HIVE_HOST=hive-metastore
HIVE_PORT=9083

# Spark master
SPARK_MASTER=local[*]

# Log level: DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
